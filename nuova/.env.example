# Real Sports Betting API Configuration
# Copy this file to .env and fill in your API keys

# JWT Secret for authentication (generate a secure random string)
JWT_SECRET=your_super_secret_jwt_key_here_min_256_bits

# Server Configuration
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# FREE SPORTS API KEYS (Get these for free!)
# ============================================

# 1. Football-Data.org (FREE - 10 calls/minute)
# Register at: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# 2. API-Football (FREE tier - 100 calls/day)
# Register at: https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here

# 3. API-Tennis (FREE tier - 100 calls/day)
# Register at: https://www.api-tennis.com/
API_TENNIS_KEY=a7979fcb1bf1274875984c07745e4f06c75bbbb7cb25161f72eed707c6d5ec7c

# 4. TheSportsDB (COMPLETELY FREE - No key needed!)
# Already integrated - no configuration needed
