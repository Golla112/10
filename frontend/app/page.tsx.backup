                padding: '12px',
                marginBottom: '12px',
                border: '1px solid rgba(255,255,255,0.1)'
              }}>
                <div style={{
                  fontSize: 'clamp(12px, 2.5vw, 14px)',
                  color: '#ffffff',
                  fontWeight: 600,
                  marginBottom: '8px'
                }}>
                  Napoli vs AC Milan
                </div>
                <div style={{
                  fontSize: 'clamp(10px, 2vw, 11px)',
                  color: '#8aa4b8',
                  marginBottom: '8px'
                }}>
                  Serie A • Sunday 20:45
                </div>
                <div style={{
                  display: 'flex',
                  gap: '8px',
                  justifyContent: 'space-between'
                }}>
                  <button style={{
                    background: '#00d4aa',
                    color: '#0a0e14',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    1.95
                  </button>
                  <button style={{
                    background: '#ff3b30',
                    color: '#ffffff',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    3.40
                  </button>
                  <button style={{
                    background: '#00d4aa',
                    color: '#0a0e14',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    3.80
                  </button>
                </div>
              </div>
              
              {/* La Liga Match */}
              <div style={{
                background: 'rgba(255,255,255,0.05)',
                borderRadius: '8px',
                padding: '12px',
                marginBottom: '12px',
                border: '1px solid rgba(255,255,255,0.1)'
              }}>
                <div style={{
                  fontSize: 'clamp(12px, 2.5vw, 14px)',
                  color: '#ffffff',
                  fontWeight: 600,
                  marginBottom: '8px'
                }}>
                  Atletico Madrid vs Barcelona
                </div>
                <div style={{
                  fontSize: 'clamp(10px, 2vw, 11px)',
                  color: '#8aa4b8',
                  marginBottom: '8px'
                }}>
                  La Liga • Saturday 21:00
                </div>
                <div style={{
                  display: 'flex',
                  gap: '8px',
                  justifyContent: 'space-between'
                }}>
                  <button style={{
                    background: '#00d4aa',
                    color: '#0a0e14',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    2.25
                  </button>
                  <button style={{
                    background: '#ff3b30',
                    color: '#ffffff',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    3.30
                  </button>
                  <button style={{
                    background: '#00d4aa',
                    color: '#0a0e14',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    3.10
                  </button>
                </div>
              </div>
              
              <button 
                onClick={() => setShowAllOdds(!showAllOdds)}
                style={{
                width: '100%',
                background: 'linear-gradient(135deg, #00d4aa 0%, #00b8a8 100%)',
                color: '#0a0e14',
                border: 'none',
                borderRadius: '8px',
                padding: '12px',
                fontSize: 'clamp(12px, 2.5vw, 14px)',
                fontWeight: 700,
                cursor: 'pointer',
                textTransform: 'uppercase',
                letterSpacing: '1px',
                boxShadow: '0 4px 12px rgba(0,212,170,0.3)',
                transition: 'all 0.2s ease'
              }}>
                {showAllOdds ? 'Nascondi Quote' : 'View All Odds →'}
              </button>
            </div>
          </div>
          
          {/* Bottom Trending Bar - Real Leagues */}
          <div style={{
            position: 'relative',
            zIndex: 2,
            background: 'rgba(0,0,0,0.4)',
            borderTop: '1px solid rgba(0,212,170,0.2)',
            padding: '12px clamp(16px, 4vw, 32px)',
            display: 'flex',
            justifyContent: 'space-between',
            alignItems: 'center',
            flexWrap: 'wrap',
            gap: '16px'
          }}>
            <div style={{
              fontSize: 'clamp(12px, 2.5vw, 14px)',
              color: '#00d4aa',
              fontWeight: 700,
              textTransform: 'uppercase',
              letterSpacing: '1px'
            }}>
              🔥 Top Leagues
            </div>
            <div style={{
              display: 'flex',
              gap: '12px',
              flexWrap: 'wrap'
            }}>
              <div style={{
                background: 'rgba(255,255,255,0.1)',
                border: '1px solid rgba(255,255,255,0.2)',
                borderRadius: '6px',
                padding: '6px 12px',
                fontSize: 'clamp(10px, 2vw, 12px)',
                color: '#ffffff',
                fontWeight: 600
              }}>
                🔴 Serie A
              </div>
              <div style={{
                background: 'rgba(255,255,255,0.1)',
                border: '1px solid rgba(255,255,255,0.2)',
                borderRadius: '6px',
                padding: '6px 12px',
                fontSize: 'clamp(10px, 2vw, 12px)',
                color: '#ffffff',
                fontWeight: 600
              }}>
                🟡 Bundesliga
              </div>
              <div style={{
                background: 'rgba(255,255,255,0.1)',
                border: '1px solid rgba(255,255,255,0.2)',
                borderRadius: '6px',
                padding: '6px 12px',
                fontSize: 'clamp(10px, 2vw, 12px)',
                color: '#ffffff',
                fontWeight: 600
              }}>
                ⚪ La Liga
              </div>
              <div style={{
                background: 'rgba(255,255,255,0.1)',
                border: '1px solid rgba(255,255,255,0.2)',
                borderRadius: '6px',
                padding: '6px 12px',
                fontSize: 'clamp(10px, 2vw, 12px)',
                color: '#ffffff',
                fontWeight: 600
              }}>
                🔵 Ligue 1
              </div>
              <div style={{
                background: 'rgba(255,255,255,0.1)',
                border: '1px solid rgba(255,255,255,0.2)',
                borderRadius: '6px',
                padding: '6px 12px',
                fontSize: 'clamp(10px, 2vw, 12px)',
                color: '#ffffff',
                fontWeight: 600
              }}>
                ⭐ UCL
              </div>
            </div>
          </div>
        </div>

        {loading && events.length === 0 && (
          <div style={{ textAlign: 'center', padding: '60px 0' }}>
            <div style={{ width: 32, height: 32, border: '2px solid rgba(0,212,170,0.2)', borderTop: '2px solid #00d4aa', borderRadius: '50%', margin: '0 auto 16px' }} />
            <div style={{ fontSize: 12, color: '#4a6070' }}>Caricamento eventi...</div>
          </div>
        )}

        {!selectedLeague && !loading && (
          <div style={{ textAlign: 'center', padding: '100px 20px', background: 'linear-gradient(180deg, #0a0e14 0%, #0d1117 100%)', minHeight: 'calc(100vh - 200px)', display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center' }}>
            <div style={{ 
              width: 80, 
              height: 80, 
              borderRadius: '50%', 
              background: 'linear-gradient(135deg, rgba(0,212,170,0.1) 0%, rgba(0,180,216,0.05) 100%)',
              display: 'flex', 
              alignItems: 'center', 
              justifyContent: 'center',
              marginBottom: 24,
              border: '1px solid rgba(0,212,170,0.2)'
            }}>
              <span style={{ fontSize: 40, opacity: 0.6 }}>{catMeta?.icon ?? '⚽'}</span>
            </div>
            <div style={{ fontSize: 16, fontWeight: 700, color: '#8aa4b8', marginBottom: 8, letterSpacing: '0.5px' }}>
              {level === 0 ? 'Seleziona uno sport' : level === 1 ? 'Seleziona una nazione' : 'Seleziona un campionato'}
            </div>
            <div style={{ fontSize: 12, color: '#4a6070', maxWidth: 300, lineHeight: 1.6 }}>
              Usa la sidebar a sinistra per navigare tra gli sport disponibili
            </div>
          </div>
        )}

        {selectedLeague && (
          <>
            <ColHeader />
            {visibleEvents.length === 0
              ? <div style={{ padding: '40px 0', textAlign: 'center', color: '#4a6070', fontSize: 12 }}>Nessun evento disponibile</div>
              : visibleEvents.map(event => <EventCard key={event.id} event={event} />)
            }
          </>
        )}
      </div>

      {/* Footer */}
      <footer style={{
        background: '#0d1117',
        borderTop: '1px solid rgba(255,255,255,0.1)',
        padding: '24px',
        textAlign: 'center'
      }}>
      </footer>

      {/* ── RIGHT SIDEBAR - SCHEDINA ── */}
      <aside style={{ 
        width: 'clamp(240px, 25vw, 280px)', 
        flexShrink: 0, 
        background: '#0d1117', 
        borderLeft: '1px solid #1a2535',
        display: 'flex',
        flexDirection: 'column',
        position: 'sticky',
        top: 66,
        height: 'calc(100vh - 66px)'
      }}>
        <InlineBetSlip />
      </aside>
    </div>
  );
}
