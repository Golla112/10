                  marginBottom: '8px'
                }}>
                  Champions League • Today 21:00
                </div>
                <div style={{
                  display: 'flex',
                  gap: '8px',
                  justifyContent: 'space-between'
                }}>
                  <button style={{
                    background: '#00d4aa',
                    color: '#0a0e14',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    2.10
                  </button>
                  <button style={{
                    background: '#ff3b30',
                    color: '#ffffff',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    3.60
                  </button>
                  <button style={{
                    background: '#00d4aa',
                    color: '#0a0e14',
                    border: 'none',
                    borderRadius: '6px',
                    padding: '8px 12px',
                    fontSize: 'clamp(11px, 2vw, 13px)',
                    fontWeight: 700,
                    cursor: 'pointer',
                    flex: 1,
                    transition: 'all 0.2s ease'
                  }}>
                    3.20
                  </button>
                </div>
              </div>
              
              {/* Serie A Match */}
              <div style={{
                background: 'rgba(255,255,255,0.05)',
