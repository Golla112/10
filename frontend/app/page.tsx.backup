                    fontSize: 'clamp(10px, 2vw, 12px)',
                    color: '#8aa4b8',
                    fontWeight: 600,
                    textTransform: 'uppercase'
                  }}>
                    Active Players
                  </div>
                </div>
              </div>
            </div>
            
            {/* Right Side - Real Featured Odds */}
