                  borderRadius: '8px',
                  padding: '12px 20px',
                  textAlign: 'center'
                }}>
                  <div style={{
                    fontSize: 'clamp(20px, 4vw, 28px)',
                    fontWeight: 900,
                    color: '#ff3b30',
